{
  "name": "pixel-playground",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "9.1.7",
    "lint-staged": "15.4.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": "9.15.9"
  },
  "volta": {
    "node": "24.15.0",
    "pnpm": "9.15.9"
  }
}
